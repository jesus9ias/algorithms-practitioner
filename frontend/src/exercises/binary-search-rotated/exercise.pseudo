FUNCTION searchRotated(arr, target):
  lo ← 0
  hi ← length(arr) - 1

  WHILE lo ≤ hi:
    mid ← floor((lo + hi) / 2)

    IF arr[mid] = target:
      RETURN mid

    IF arr[lo] ≤ arr[mid]:
      IF arr[lo] ≤ target AND target < arr[mid]:
        hi ← mid - 1
      ELSE:
        lo ← mid + 1
    ELSE:
      IF arr[mid] < target AND target ≤ arr[hi]:
        lo ← mid + 1
      ELSE:
        hi ← mid - 1

  RETURN -1
