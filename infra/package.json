    "deploy": "node scripts/cdk.js deploy",
    "destroy": "node scripts/cdk.js destroy"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "aws-cdk": "^2.170.0",
    "dotenv-cli": "^11.0.0",
