{
  "name": "algo-dsa-infra",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for the algorithms-practitioner learning platform",
  "private": true,
  "bin": {
    "algo-dsa-infra": "bin/app.js"
  },
  "scripts": {
